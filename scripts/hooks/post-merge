#!/usr/bin/env bash
# post-merge: re-apply canonical hooks after merge-based git pull (WRK-312)
# Fires on: git pull --no-rebase (merge), git pull --ff-only (fast-forward)
set -euo pipefail
REPO_ROOT="$(git rev-parse --show-toplevel)"
bash "$REPO_ROOT/scripts/setup/install-all-hooks.sh" --quiet

# Rebuild symbol index if src/ files changed (WRK-1085)
if git diff --name-only ORIG_HEAD HEAD 2>/dev/null | grep -q '/src/'; then
    uv run --no-project python "$REPO_ROOT/scripts/search/build-symbol-index.py" --quiet
fi

# Remove ghost pending items restored by the merge (WRK-1138)
bash "$REPO_ROOT/scripts/work-queue/scan-ghost-pending.sh" --fix --quiet 2>/dev/null || true
